# LectureLens Frontend — Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL (Points to FastAPI backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth / Auth.js Configuration (Required for user authentication)
# Generate a secret via: `openssl rand -base64 32`
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Credentials (Required for Google Login)
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth Credentials (Optional, for GitHub login)
# Get these from GitHub Developer Settings: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
