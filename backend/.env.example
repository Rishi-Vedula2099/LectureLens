# LectureLens Backend — Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required for AI features like transcript analysis, RAG, and notes generation)
OPENAI_API_KEY=your_openai_api_key_here

# Database Connection (PostgreSQL via Neon or local)
# Example: postgresql+asyncpg://user:password@localhost:5432/lecturelens
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lecturelens

# Chroma Vector Database Directory (Optional, used for RAG)
CHROMA_PERSIST_DIR=./chroma_db

# Application Secret Key (Required for backend security tokens)
# Generate one via: `openssl rand -hex 32`
SECRET_KEY=your_generated_secret_key_here
